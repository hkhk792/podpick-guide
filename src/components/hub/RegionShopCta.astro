---
import { AU_SHOP_LABEL } from "../../config";
import { shopUrl, AU_SHOP_PATHS } from "../../lib/shopLinks";

interface Props {
  region?: "australia";
  label?: string;
  /** Deep path on ailibarbar.com, e.g. /guides/... or /product/... */
  href?: string;
}

const { label, href } = Astro.props;
const shopHref = href ? (href.startsWith("http") ? href : shopUrl(href)) : shopUrl(AU_SHOP_PATHS.home);
const shopLabel = label ?? AU_SHOP_LABEL;
---

<aside class="region-cta" aria-label="Official store">
  <p>
    Ready to check stock? Visit <a href={shopHref} rel="noopener noreferrer"><strong>{shopLabel}</strong></a>
    for current availability and specifications on the official Australia store.
  </p>
  <a class="btn btn--shop" href={shopHref} rel="noopener noreferrer">Visit store</a>
</aside>
