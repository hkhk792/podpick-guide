---
import { AU_SHOP_URL, AU_SHOP_LABEL } from "../config";
import { shopUrl, AU_SHOP_PATHS } from "../lib/shopLinks";

interface Props {
  href?: string;
  label?: string;
}

const { href, label } = Astro.props;
const shopHref = href ? (href.startsWith("http") ? href : shopUrl(href)) : AU_SHOP_URL;
const shopLabel = label ?? AU_SHOP_LABEL;
---

<aside class="shop-cta" aria-label="Official Australia store">
  <p>
    If you have narrowed a flavour or pack size, check live stock on
    <strong><a href={shopHref} rel="noopener noreferrer">{shopLabel}</a></strong>.
    This site is editorial only — we do not process orders here.
  </p>
  <div class="shop-cta__actions">
    <a class="btn btn--shop" href={shopHref} rel="noopener noreferrer">Go to {shopLabel}</a>
    <a class="btn" href={shopUrl(AU_SHOP_PATHS.buyingGuide)} rel="noopener noreferrer">AU buying guide on store</a>
  </div>
</aside>
