---
import "../styles/global.css";
import {
  AU_SHOP_URL,
  AU_SHOP_LABEL,
  GA_MEASUREMENT_ID,
  GITHUB_ORG_LABEL,
  GITHUB_ORG_URL,
  SITE_NAME,
  SITE_URL,
} from "../config";
import { MAIN_NAV } from "../data/hub/navigation";
import { AUSTRALIA_SECTION_NAV } from "../data/hub/australiaSections";
import {
  buildHreflangAlternates,
  type HreflangAlt,
} from "../lib/seo";

interface Props {
  title: string;
  description: string;
  path?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  narrow?: boolean;
  wide?: boolean;
  lang?: string;
  locale?: string;
  /** Override auto hreflang pairs when a true translation URL exists. */
  hreflang?: HreflangAlt[];
  ogType?: "website" | "article";
}

const {
  title,
  description,
  path = "",
  ogImage = "/images/australia/hero-device.png",
  jsonLd,
  narrow = false,
  wide = false,
  lang = "en",
  locale = "en-AU",
  hreflang,
  ogType,
} = Astro.props;

const isHome = path === "" || path === "/";
const canonical = new URL(path.replace(/^\//, "") || "", SITE_URL).href;
const ogImageUrl = new URL(ogImage, SITE_URL).href;
const fullTitle = isHome ? title : `${title} | ${SITE_NAME}`;
const mainClass = narrow
  ? "container container--narrow"
  : wide
    ? "container container--wide"
    : "container";
const jsonLdList = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const ogLocale = "en_AU";
const resolvedOgType = ogType ?? (isHome ? "website" : "article");
const hreflangAlts = hreflang ?? buildHreflangAlternates(path, lang);
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION ?? "";
const bingSiteVerification = import.meta.env.PUBLIC_BING_SITE_VERIFICATION ?? "";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.png" type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="alternate" type="application/rss+xml" title={SITE_NAME} href="/rss.xml" />
    <link rel="canonical" href={canonical} />
    {
      hreflangAlts.map((alt) => (
        <link rel="alternate" hreflang={alt.lang} href={alt.href} />
      ))
    }
    <meta name="robots" content="index, follow" />
    <meta name="p:domain_verify" content="1a79f87202f28166ad283df9bf776977" />
    {
      googleSiteVerification ? (
        <meta name="google-site-verification" content={googleSiteVerification} />
      ) : null
    }
    {
      bingSiteVerification ? (
        <meta name="msvalidate.01" content={bingSiteVerification} />
      ) : null
    }
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:type" content={resolvedOgType} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    {
      jsonLdList.map((node) => (
        <script type="application/ld+json" set:html={JSON.stringify(node)} />
      ))
    }
    {
      GA_MEASUREMENT_ID ? (
        <>
          <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`} />
          <script
            is:inline
            set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${GA_MEASUREMENT_ID}');`}
          />
        </>
      ) : null
    }
  </head>
  <body>
    <header class="site-header site-header--hub">
      <div class="container container--wide site-header__top">
        <a class="brand" href="/">
          <img src="/favicon.svg" alt="" width="28" height="28" />
          {SITE_NAME}
        </a>
        <a class="region-pill region-pill--solo" href="/australia">
          <span aria-hidden="true">🇦🇺</span> Australia
        </a>
      </div>
      <div class="container container--wide site-header__navrow">
        <nav class="hub-nav" aria-label="Main navigation">
          {MAIN_NAV.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>
        <div class="header-shops">
          <a class="header-shop header-shop--au" href={AU_SHOP_URL} rel="noopener noreferrer">{AU_SHOP_LABEL}</a>
        </div>
      </div>
    </header>
    <main class={mainClass}>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container container--wide footer-grid">
        <div>
          <strong>{SITE_NAME}</strong>
          <p>Independent Australia disposable vape reviews, buying guides and comparisons for adult consumers (18+).</p>
        </div>
        <div>
          <strong>Australia</strong>
          <p>
            <a href="/australia">Australia hub</a> · <a href="/buying-guides">Buying guides</a>
          </p>
        </div>
        <div>
          <strong>Australia Columns</strong>
          <p>
            {
              AUSTRALIA_SECTION_NAV.map((item, i) => (
                <>
                  {i > 0 ? " · " : null}
                  <a href={item.href}>{item.label}</a>
                </>
              ))
            }
          </p>
        </div>
        <div>
          <strong>Official store</strong>
          <p>
            <a href={AU_SHOP_URL} rel="noopener noreferrer">www.ailibarbar.com</a>
          </p>
        </div>
        <div>
          <strong>About</strong>
          <p>
            <a href="/about">About</a> · <a href="/contact">Contact</a> ·
            <a href="/author/jason-chen">Editor</a>
          </p>
        </div>
        <div>
          <strong>Open Data</strong>
          <p>
            <a href={GITHUB_ORG_URL} rel="noopener noreferrer me">{GITHUB_ORG_LABEL}</a>
            · <a href="/rss.xml">RSS</a>
          </p>
        </div>
      </div>
      <div class="container container--wide footer-note">
        <p>Adults 18+ only. Not medical or legal advice. Follow Australian regulations.</p>
      </div>
    </footer>
  </body>
</html>
