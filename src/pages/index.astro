---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContentCard from "../components/hub/ContentCard.astro";
import {
  SITE_NAME,
  SITE_SUBTITLE,
  SITE_TAGLINE,
  SITE_URL,
  AU_SHOP_URL,
  AU_SHOP_LABEL,
} from "../config";
import { HOME_BRANDS, HOME_GUIDE_LINKS } from "../data/hub/navigation";
import { hubBrands } from "../data/hub/brands";
import { hubComparisons } from "../data/hub/comparisons";
import { hubProducts } from "../data/hub/products";
import { hubGuides } from "../data/hub/guides";
import { hubReviews } from "../data/hub/reviews";
import { buildOrganizationJsonLd, buildWebSiteJsonLd } from "../lib/seo";

const title = `${SITE_NAME} — ${SITE_TAGLINE}`;
const description = SITE_SUBTITLE;

const editorPicks = [
  hubProducts.find((p) => p.slug === "alibarbar-ingot-9000")!,
  hubComparisons.find((c) => c.slug === "alibarbar-vs-iget")!,
  hubGuides.find((g) => g.slug === "best-disposable-vape-australia")!,
].filter(Boolean);

const latestGuides = hubGuides.slice(0, 6);
const latestReviews = hubReviews.slice(0, 3);

const jsonLd = [
  buildWebSiteJsonLd(description),
  buildOrganizationJsonLd(),
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "Popular brands",
    itemListElement: HOME_BRANDS.map((b, i) => ({
      "@type": "ListItem",
      position: i + 1,
      name: b.name,
      url: `${SITE_URL}/brands/${b.slug}`,
    })),
  },
];
---

<BaseLayout title={title} description={description} path="/" wide jsonLd={jsonLd} lang="en" locale="en-AU">
  <section class="hub-hero">
    <div class="hub-hero__copy">
      <p class="kicker">Australia · Adults 18+</p>
      <h1>{SITE_TAGLINE}</h1>
      <p class="lead">{SITE_SUBTITLE}</p>
      <div class="hub-hero__tags">
        <span>Independent Reviews</span>
        <span>Buying Guides</span>
        <span>Comparisons</span>
      </div>
      <p class="hub-hero__cta">
        <a class="btn btn--shop" href="/australia">Explore Australia hub</a>
        <a class="btn" href={AU_SHOP_URL} rel="noopener noreferrer">{AU_SHOP_LABEL}</a>
      </p>
    </div>
    <div class="hub-hero__regions">
      <h2 class="section-kicker">Focus market</h2>
      <div class="region-cards">
        <a class="region-card region-card--au" href="/australia">
          <span class="region-card__flag">🇦🇺</span>
          <strong>Australia</strong>
          <span>Best disposable round-up, Alibarbar, IGET, HQD &amp; KUZ columns</span>
        </a>
      </div>
    </div>
  </section>

  <section class="hub-section">
    <h2 class="section-title">Popular Brands</h2>
    <div class="hub-card-grid hub-card-grid--brands">
      {
        HOME_BRANDS.map((b) => {
          const brand = hubBrands.find((x) => x.slug === b.slug);
          return (
            <a class="brand-chip" href={`/brands/${b.slug}`}>
              {b.name}
            </a>
          );
        })
      }
    </div>
  </section>

  <section class="hub-section">
    <h2 class="section-title">Knowledge Hubs</h2>
    <div class="hub-card-grid">
      {
        HOME_GUIDE_LINKS.map((g) => (
          <a class="hub-tile" href={g.href}>
            <strong>{g.label}</strong>
          </a>
        ))
      }
    </div>
  </section>

  <section class="hub-section">
    <h2 class="section-title">Editor's Choice</h2>
    <div class="hub-card-grid">
      {
        editorPicks.map((item) => (
          <ContentCard
            href={
              "brandSlug" in item && "specifications" in item
                ? `/products/${item.slug}`
                : "leftLabel" in item
                  ? `/comparisons/${item.slug}`
                  : `/buying-guides/${item.slug}`
            }
            title={item.title}
            description={item.description}
            image={item.heroImage}
            imageAlt={"imageAlt" in item ? item.imageAlt : item.title}
            tag={
              "specifications" in item
                ? "Product"
                : "leftLabel" in item
                  ? "Comparison"
                  : "Guide"
            }
          />
        ))
      }
    </div>
  </section>

  <section class="hub-section">
    <h2 class="section-title">Latest Buying Guides</h2>
    <div class="hub-card-grid">
      {
        latestGuides.map((g) => (
          <ContentCard
            href={`/buying-guides/${g.slug}`}
            title={g.title}
            description={g.description}
            image={g.heroImage}
            imageAlt={g.imageAlt}
            tag={g.category}
          />
        ))
      }
    </div>
    <p class="hub-more"><a href="/buying-guides">All buying guides →</a> · <a href="/australia">Australia hub →</a></p>
  </section>

  <section class="hub-section">
    <h2 class="section-title">Flavour Reviews</h2>
    <div class="hub-card-grid">
      {
        latestReviews.map((r) => (
          <ContentCard
            href={`/reviews/${r.slug}`}
            title={r.title}
            description={r.description}
            image={r.heroImage}
            imageAlt={r.imageAlt}
            tag={r.category}
          />
        ))
      }
    </div>
    <p class="hub-more"><a href="/reviews">All reviews →</a></p>
  </section>
</BaseLayout>
