---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HubBreadcrumb from "../../components/hub/HubBreadcrumb.astro";
import ContentCard from "../../components/hub/ContentCard.astro";
import AustraliaSectionNav from "../../components/hub/AustraliaSectionNav.astro";
import ReviewPhotoStrip from "../../components/hub/ReviewPhotoStrip.astro";
import RegionShopCta from "../../components/hub/RegionShopCta.astro";
import { REGIONS } from "../../config";
import {
  AUSTRALIA_SECTIONS,
  AU_EDITORIAL_BRANDS,
} from "../../data/hub/australiaSections";
import { hubComparisons } from "../../data/hub/comparisons";
import { hubNewsPosts } from "../../data/hub/news";

const au = REGIONS.australia;
const auComparisons = hubComparisons.filter((c) => c.region === "australia");
const auNews = hubNewsPosts.filter((n) => n.region === "australia").slice(0, 4);

const title = "Australia — Disposable Vape Media & Buying Guides";
const description =
  "Independent Australia vape media: best disposable round-up, Alibarbar, IGET, HQD and KUZ brand columns, comparisons and market news.";
---

<BaseLayout title={title} description={description} path="/australia" ogImage={au.heroImage} wide lang="en">
  <HubBreadcrumb items={[{ label: "Australia" }]} />
  <AustraliaSectionNav current="/australia" />

  <header class="hub-index-header hub-index-header--region">
    <span class="region-card__flag">🇦🇺</span>
    <h1>Australia</h1>
    <p class="lead">
      Independent English editorial for the Australian disposable market — brand columns, head-to-head comparisons and buying guides across Alibarbar, IGET, HQD and KUZ.
    </p>
  </header>

  <figure class="article-hero article-hero--region">
    <img src={au.heroImage} alt="Australian disposable vape market guides" width="1200" height="675" loading="eager" />
    <ReviewPhotoStrip limit={10} label="Market photos and customer shots" />
  </figure>

  <section class="hub-section">
    <h2 class="section-title">Editorial Columns</h2>
    <p class="muted hub-section-intro">
      Browse by topic — each column collects guides, comparisons and brand context in one place.
    </p>
    <div class="australia-editorial-grid">
      {
        AUSTRALIA_SECTIONS.map((s) => (
          <a class="australia-editorial-card" href={`/australia/${s.slug}`}>
            <img src={s.heroImage} alt="" loading="lazy" width="400" height="225" />
            <strong>{s.title}</strong>
            <span>{s.description}</span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="hub-section">
    <h2 class="section-title">Brands We Cover</h2>
    <div class="hub-card-grid">
      {
        AU_EDITORIAL_BRANDS.map((b) => (
          <ContentCard
            href={`/brands/${b.slug}`}
            title={b.name}
            description={b.description}
            image={b.heroImage}
            imageAlt={b.imageAlt}
            tag="Brand"
          />
        ))
      }
    </div>
  </section>

  <section class="hub-section">
    <h2 class="section-title">Head-to-Head Comparisons</h2>
    <div class="hub-card-grid">
      {
        auComparisons.map((c) => (
          <ContentCard
            href={`/comparisons/${c.slug}`}
            title={c.title}
            description={c.description}
            image={c.heroImage}
            imageAlt={c.imageAlt}
            tag="Comparison"
          />
        ))
      }
    </div>
  </section>

  {
    auNews.length ? (
      <section class="hub-section">
        <h2 class="section-title">Australia News</h2>
        <div class="hub-card-grid">
          {
            auNews.map((n) => (
              <ContentCard href={`/news/${n.slug}`} title={n.title} description={n.excerpt} image={n.heroImage} tag={n.weekTag} />
            ))
          }
        </div>
      </section>
    ) : null
  }

  <RegionShopCta region="australia" />
</BaseLayout>
