---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HubBreadcrumb from "../../components/hub/HubBreadcrumb.astro";
import ContentCard from "../../components/hub/ContentCard.astro";
import { hubGuides } from "../../data/hub/guides";
import { AUSTRALIA_SECTIONS } from "../../data/hub/australiaSections";
import { SITE_URL } from "../../config";
import { buildCollectionPageJsonLd } from "../../lib/seo";

const title = "Buying Guides — How to Choose Disposable Vapes in Australia";
const description =
  "Australia buying guides for Alibarbar Ingot 9000, laws overview, puff capacity, flavours and brand comparisons.";

const extraGuides = hubGuides.filter(
  (g) =>
    ![
      "best-disposable-vape-australia",
      "how-to-use-a-disposable-vape",
      "disposable-vape-laws-in-australia",
    ].includes(g.slug) && !g.brandSlug
);

const jsonLd = buildCollectionPageJsonLd(
  title,
  description,
  "/buying-guides",
  hubGuides.map((g) => ({ name: g.title, url: `${SITE_URL}/buying-guides/${g.slug}` }))
);
---

<BaseLayout title={title} description={description} path="/buying-guides" wide jsonLd={jsonLd} lang="en" locale="en-AU">
  <HubBreadcrumb items={[{ label: "Buying Guides" }]} />
  <header class="hub-index-header">
    <h1>Buying Guides</h1>
    <p class="lead">
      Australia guides organised by editorial column on the
      <a href="/australia">Australia hub</a>. Start with laws, capacity and flavour fit before you buy.
    </p>
  </header>

  {
    AUSTRALIA_SECTIONS.map((section) => {
      const sectionGuides =
        section.slug === "best-disposable-vape"
          ? hubGuides.filter((g) =>
              [
                "best-disposable-vape-australia",
                "how-to-use-a-disposable-vape",
                "disposable-vape-laws-in-australia",
                "alibarbar-buying-guide-australia",
                "high-puff-disposable-capacity-australia-2026",
                "how-to-make-disposable-vape-last-longer",
              ].includes(g.slug)
            )
          : section.brandSlug
            ? hubGuides.filter((g) => g.brandSlug === section.brandSlug)
            : [];
      if (!sectionGuides.length) return null;
      return (
        <section class="hub-section">
          <h2 class="section-title">
            <a href={`/australia/${section.slug}`}>{section.title}</a>
          </h2>
          <div class="hub-card-grid">
            {sectionGuides.map((g) => (
              <ContentCard
                href={`/buying-guides/${g.slug}`}
                title={g.title}
                description={g.description}
                image={g.heroImage}
                imageAlt={g.imageAlt}
                tag={g.category}
              />
            ))}
          </div>
        </section>
      );
    })
  }

  {
    extraGuides.length ? (
      <section class="hub-section">
        <h2 class="section-title">More guides</h2>
        <div class="hub-card-grid">
          {extraGuides.map((g) => (
            <ContentCard
              href={`/buying-guides/${g.slug}`}
              title={g.title}
              description={g.description}
              image={g.heroImage}
              imageAlt={g.imageAlt}
              tag={g.category}
            />
          ))}
        </div>
      </section>
    ) : null
  }
</BaseLayout>
