---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HubBreadcrumb from "../../components/hub/HubBreadcrumb.astro";
import ContentCard from "../../components/hub/ContentCard.astro";
import { hubGuides } from "../../data/hub/guides";
import { AUSTRALIA_SECTIONS } from "../../data/hub/australiaSections";
import { articles } from "../../data/articles";
import { SITE_URL } from "../../config";
import { buildCollectionPageJsonLd } from "../../lib/seo";

const twBuying = articles.filter((a) =>
  ["新手指南", "選購對比", "入門知識", "旅行須知"].includes(a.category)
);

const title = "Buying Guides — How to Choose Vape Products";
const description =
  "Australia brand columns and English buying guides plus Taiwan Traditional Chinese purchase references.";

const jsonLd = buildCollectionPageJsonLd(
  title,
  description,
  "/buying-guides",
  hubGuides.map((g) => ({ name: g.title, url: `${SITE_URL}/buying-guides/${g.slug}` }))
);
---

<BaseLayout title={title} description={description} path="/buying-guides" wide jsonLd={jsonLd} lang="en">
  <HubBreadcrumb items={[{ label: "Buying Guides" }]} />
  <header class="hub-index-header">
    <h1>Buying Guides</h1>
    <p class="lead">
      Australia guides are organised by editorial column on the
      <a href="/australia">Australia hub</a>. Taiwan articles remain in Traditional Chinese.
    </p>
  </header>

  {
    AUSTRALIA_SECTIONS.map((section) => {
      const sectionGuides =
        section.slug === "best-disposable-vape"
          ? hubGuides.filter((g) =>
              ["best-disposable-vape-australia", "how-to-use-a-disposable-vape", "disposable-vape-laws-in-australia"].includes(
                g.slug
              )
            )
          : section.brandSlug
            ? hubGuides.filter((g) => g.brandSlug === section.brandSlug)
            : [];
      if (!sectionGuides.length) return null;
      return (
        <section class="hub-section">
          <h2 class="section-title">
            <a href={`/australia/${section.slug}`}>{section.title}</a>
          </h2>
          <div class="hub-card-grid">
            {sectionGuides.map((g) => (
              <ContentCard
                href={`/buying-guides/${g.slug}`}
                title={g.title}
                description={g.description}
                image={g.heroImage}
                imageAlt={g.imageAlt}
                tag={g.category}
              />
            ))}
          </div>
        </section>
      );
    })
  }

  <h2 class="section-title">Taiwan Guides (繁體)</h2>
  <div class="hub-card-grid">
    {
      twBuying.map((a) => (
        <ContentCard
          href={`/${a.slug}`}
          title={a.title}
          description={a.description}
          image={a.heroImage}
          imageAlt={a.imageAlt}
          tag={a.category}
        />
      ))
    }
  </div>
</BaseLayout>
