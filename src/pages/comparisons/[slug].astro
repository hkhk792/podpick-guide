---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HubBreadcrumb from "../../components/hub/HubBreadcrumb.astro";
import RegionShopCta from "../../components/hub/RegionShopCta.astro";
import ContentCard from "../../components/hub/ContentCard.astro";
import ReviewPhotoStrip from "../../components/hub/ReviewPhotoStrip.astro";
import { hubComparisons, getComparison } from "../../data/hub/comparisons";
import { getBrand } from "../../data/hub/brands";
import { getProduct } from "../../data/hub/products";
import { buildFaqJsonLd } from "../../lib/seo";

export function getStaticPaths() {
  return hubComparisons.map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const cmp = getComparison(slug!)!;
const region = cmp.region === "taiwan" ? "taiwan" : "australia";
const jsonLd = cmp.faq.length ? [buildFaqJsonLd(cmp.faq.map((f) => ({ q: f.q, a: f.a })))] : [];
const otherComparisons = hubComparisons.filter((c) => c.slug !== cmp.slug && c.region === cmp.region).slice(0, 3);
const relatedBrands = cmp.relatedSlugs.map((s) => getBrand(s)).filter(Boolean);
const relatedProducts = cmp.relatedSlugs.map((s) => getProduct(s)).filter(Boolean);
---

<BaseLayout
  title={cmp.title}
  description={cmp.description}
  path={`/comparisons/${cmp.slug}`}
  ogImage={cmp.heroImage}
  jsonLd={jsonLd}
  narrow
  lang={cmp.region === "taiwan" ? "zh-Hant-TW" : "en"}
>
  <article class="hub-doc">
    <HubBreadcrumb items={[{ label: "Comparisons", href: "/comparisons" }, { label: cmp.title }]} />

    <header class="article-header">
      <h1>{cmp.title}</h1>
      <p class="lead">{cmp.intro}</p>
    </header>

    <figure class="article-hero">
      <img src={cmp.heroImage} alt={cmp.imageAlt} width="1200" height="675" loading="eager" />
      {region === "australia" ? <ReviewPhotoStrip limit={8} label="Real customer photos" /> : null}
    </figure>

    <section class="geo-block geo-tldr">
      <h2>Quick Winner</h2>
      <p>{cmp.quickWinner}</p>
    </section>

    <section>
      <h2>Comparison Table</h2>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th scope="col">Feature</th>
              <th scope="col">{cmp.leftLabel}</th>
              <th scope="col">{cmp.rightLabel}</th>
            </tr>
          </thead>
          <tbody>
            {
              cmp.rows.map((row) => (
                <tr>
                  <th scope="row">{row.feature}</th>
                  <td>{row.left}</td>
                  <td>{row.right}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </section>

    <section class="pros-cons">
      <div class="pros-cons__col pros-cons__col--pros">
        <h2>{cmp.leftLabel} — Strengths</h2>
        <ul>{cmp.leftStrengths.map((s) => <li>{s}</li>)}</ul>
      </div>
      <div class="pros-cons__col pros-cons__col--cons">
        <h2>{cmp.rightLabel} — Strengths</h2>
        <ul>{cmp.rightStrengths.map((s) => <li>{s}</li>)}</ul>
      </div>
    </section>

    <section>
      <h2>Verdict</h2>
      {cmp.verdict.map((p) => <p>{p}</p>)}
    </section>

    {
      cmp.faq.length ? (
        <section class="faq">
          <h2>FAQ</h2>
          <dl>
            {cmp.faq.map((f) => (
              <>
                <dt>{f.q}</dt>
                <dd>{f.a}</dd>
              </>
            ))}
          </dl>
        </section>
      ) : null
    }

    {
      otherComparisons.length ? (
        <section>
          <h2>More Comparisons</h2>
          <div class="hub-card-grid">
            {otherComparisons.map((c) => (
              <ContentCard
                href={`/comparisons/${c.slug}`}
                title={c.title}
                description={c.description}
                image={c.heroImage}
                imageAlt={c.imageAlt}
                tag={c.region}
              />
            ))}
          </div>
        </section>
      ) : null
    }

    {
      relatedBrands.length || relatedProducts.length ? (
        <section>
          <h2>Related Brands & Products</h2>
          <div class="hub-card-grid">
            {relatedBrands.map((b) => (
              <ContentCard
                href={`/brands/${b!.slug}`}
                title={b!.name}
                description={b!.description}
                image={b!.heroImage}
                imageAlt={b!.imageAlt}
                tag="Brand"
              />
            ))}
            {relatedProducts.map((p) => (
              <ContentCard
                href={`/products/${p!.slug}`}
                title={p!.name}
                description={p!.description}
                image={p!.heroImage}
                imageAlt={p!.imageAlt}
                tag="Product"
              />
            ))}
          </div>
        </section>
      ) : null
    }

    <RegionShopCta region={region} />
  </article>
</BaseLayout>
