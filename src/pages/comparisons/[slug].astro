---
import ComparisonDoc from "../../components/hub/ComparisonDoc.astro";
import { hubComparisons, getComparison } from "../../data/hub/comparisons";

export function getStaticPaths() {
  return hubComparisons.filter((c) => !c.path).map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const cmp = getComparison(slug!)!;
---

<ComparisonDoc cmp={cmp} path={`/comparisons/${cmp.slug}`} />
