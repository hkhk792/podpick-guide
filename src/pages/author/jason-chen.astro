---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { DEFAULT_AUTHOR, buildAuthorPersonJsonLd } from "../../data/author";
import { hubGuides } from "../../data/hub/guides";
import { hubReviews } from "../../data/hub/reviews";
import { buildOrganizationJsonLd } from "../../lib/seo";
import { SITE_URL } from "../../config";

const title = `${DEFAULT_AUTHOR.name} — Editor, PodPick Guide`;
const description = DEFAULT_AUTHOR.bio;

const recent = [
  ...hubGuides.slice(0, 4).map((g) => ({ href: `/buying-guides/${g.slug}`, title: g.title })),
  ...hubReviews.slice(0, 4).map((r) => ({ href: `/reviews/${r.slug}`, title: r.title })),
];

const jsonLd = [
  buildOrganizationJsonLd(),
  {
    "@context": "https://schema.org",
    ...buildAuthorPersonJsonLd(),
    url: DEFAULT_AUTHOR.url,
    image: new URL(DEFAULT_AUTHOR.image, SITE_URL).href,
  },
];
---

<BaseLayout title={title} description={description} path="/author/jason-chen" jsonLd={jsonLd} narrow lang="en" locale="en-AU">
  <article class="static-page author-page">
    <header class="author-page__header">
      <img
        src={DEFAULT_AUTHOR.image}
        alt={`${DEFAULT_AUTHOR.name} avatar`}
        width="96"
        height="96"
        class="author-page__avatar"
      />
      <div>
        <h1>{DEFAULT_AUTHOR.name}</h1>
        <p class="author-page__title">{DEFAULT_AUTHOR.title ?? "Editor"} · Australia disposable reviews</p>
        <p class="author-page__stats">
          Publishing since {DEFAULT_AUTHOR.experienceSince} · {DEFAULT_AUTHOR.reviewsCount}+ product notes
        </p>
      </div>
    </header>

    <section>
      <h2>About</h2>
      <p>{DEFAULT_AUTHOR.bio}</p>
    </section>

    <section>
      <h2>Expertise</h2>
      <p class="entity-tags">
        {DEFAULT_AUTHOR.expertise.map((tag) => (
          <span class="entity-tag">{tag}</span>
        ))}
      </p>
    </section>

    <section>
      <h2>Testing method</h2>
      <ol>
        {DEFAULT_AUTHOR.testingMethod.map((step) => (
          <li>{step}</li>
        ))}
      </ol>
    </section>

    <section>
      <h2>Recent work</h2>
      <ul>
        {recent.map((a) => (
          <li>
            <a href={a.href}>{a.title}</a>
          </li>
        ))}
      </ul>
      <p><a href="/buying-guides">All buying guides →</a> · <a href="/reviews">All reviews →</a></p>
    </section>
  </article>
</BaseLayout>
