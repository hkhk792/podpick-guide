---
import BaseLayout from "../layouts/BaseLayout.astro";
import ShopCta from "../components/ShopCta.astro";
import { SITE_NAME, AU_SHOP_URL, AU_SHOP_LABEL } from "../config";
import { DEFAULT_AUTHOR } from "../data/author";
import { buildOrganizationJsonLd, buildWebSiteJsonLd } from "../lib/seo";

const title = `About ${SITE_NAME}`;
const description =
  "PodPick Guide is an independent Australia disposable vape media hub — reviews, buying guides and comparisons for adult consumers (18+).";

const jsonLd = [
  buildWebSiteJsonLd(description),
  buildOrganizationJsonLd(),
];
---

<BaseLayout title={title} description={description} path="/about" jsonLd={jsonLd} narrow lang="en" locale="en-AU">
  <article class="static-page">
    <header class="article-header">
      <h1>About PodPick Guide</h1>
      <p class="lead">
        We publish independent English reviews, flavour guides and head-to-head comparisons for the Australian disposable vape market — so adult buyers can understand specs, trade-offs and flavour fit before they shop.
      </p>
    </header>

    <section>
      <h2>What we cover</h2>
      <ul>
        <li>Alibarbar Ingot 9000 product explainers, puff/capacity notes and flavour reviews</li>
        <li>Comparisons vs IGET, HQD, Gunnpod, KUZ and RELX formats</li>
        <li>Australia buying guides, laws overview and authenticity FAQ</li>
        <li>Practical usage tips: storage, draw style and making a device last longer</li>
      </ul>
    </section>

    <section>
      <h2>Editorial standards (E-E-A-T)</h2>
      <p>
        Articles are reviewed by editor <a href={DEFAULT_AUTHOR.url}>{DEFAULT_AUTHOR.name}</a>.
        We prefer clear specs, comparison tables, visible last-updated dates and FAQ blocks over hype.
        Content is for adults 18+ only and is not medical or legal advice — follow Australian regulations and retailer age checks.
      </p>
    </section>

    <section>
      <h2>Relationship to the store</h2>
      <p>
        End-of-page CTAs link to
        <a href={AU_SHOP_URL} rel="noopener noreferrer">{AU_SHOP_LABEL}</a>
        so you can check live stock and pack options after reading. Editorial pages stay independent; we do not process orders on this site.
      </p>
    </section>

    <ShopCta />

    <section>
      <h2>Start here</h2>
      <ul>
        <li><a href="/australia">Australia hub</a></li>
        <li><a href="/buying-guides/best-disposable-vape-australia">Best disposable vape Australia</a></li>
        <li><a href="/products/alibarbar-ingot-9000">Alibarbar Ingot 9000</a></li>
        <li><a href="/comparisons/alibarbar-vs-iget">Alibarbar vs IGET</a></li>
        <li><a href="/buying-guides/disposable-vape-laws-in-australia">Disposable vape laws in Australia</a></li>
      </ul>
    </section>
  </article>
</BaseLayout>
