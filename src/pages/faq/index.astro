---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HubBreadcrumb from "../../components/hub/HubBreadcrumb.astro";
import ContentCard from "../../components/hub/ContentCard.astro";
import { hubFaqTopics, countFaqItems } from "../../data/hub/faq";
import { SITE_URL } from "../../config";
import { buildCollectionPageJsonLd } from "../../lib/seo";

const total = countFaqItems();
const title = "FAQ Center — Vape Questions Answered";
const description = `Structured FAQ hub with ${total}+ answers across charging, battery, flavours, shipping, compatibility, safety and regional topics.`;

const jsonLd = buildCollectionPageJsonLd(
  title,
  description,
  "/faq",
  hubFaqTopics.map((t) => ({ name: t.title, url: `${SITE_URL}/faq/${t.slug}` }))
);
---

<BaseLayout title={title} description={description} path="/faq" wide jsonLd={jsonLd} lang="en">
  <HubBreadcrumb items={[{ label: "FAQ" }]} />
  <header class="hub-index-header">
    <h1>FAQ Center</h1>
    <p class="lead">{total} answers across {hubFaqTopics.length} topics — built for featured snippets and AI citation.</p>
  </header>
  <div class="hub-card-grid">
    {
      hubFaqTopics.map((t) => (
        <ContentCard
          href={`/faq/${t.slug}`}
          title={t.title}
          description={t.description}
          tag={`${t.items.length} Q&A`}
        />
      ))
    }
  </div>
</BaseLayout>
